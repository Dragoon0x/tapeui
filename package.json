{
  "name": "usetapeui",
  "version": "1.0.0",
  "description": "Voice + click + vision design intent capture for AI agents. Talk, click, ship.",
  "keywords": [
    "design",
    "critique",
    "voice",
    "react",
    "vue",
    "svelte",
    "ai",
    "agent",
    "cursor",
    "claude",
    "copilot",
    "mcp",
    "tape",
    "design-system",
    "tailwind",
    "intent",
    "review"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.mjs",
      "require": "./dist/vanilla.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.mjs",
      "require": "./dist/svelte.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    }
  },
  "bin": {
    "usetapeui": "./dist/mcp/cli.js"
  },
  "files": [
    "dist",
    "extension",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node test/run.js",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://dragoon0x.github.io/tapeui/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dragoon0x/tapeui.git"
  },
  "bugs": {
    "url": "https://github.com/Dragoon0x/tapeui/issues"
  },
  "author": "Dragoon0x",
  "license": "MIT"
}
