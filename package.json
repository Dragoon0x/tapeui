{
  "name": "usetapeui",
  "version": "0.1.0",
  "description": "Record design critiques by talking and clicking. Voice gets transcribed, clicks get pinned to selectors with computed styles. Output is a structured review your AI agent can action.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "node test/run.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "tape", "design-critique", "voice", "speech-recognition",
    "recording", "review", "feedback", "ai-agent", "cursor",
    "claude-code", "copilot", "devtools", "react"
  ],
  "author": "0xDragoon",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/dragoon0x/tapeui" },
  "homepage": "https://dragoon0x.github.io/tapeui/",
  "sideEffects": false
}
